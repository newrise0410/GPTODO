# LLM 백엔드 설정 (셋 중 하나)

# 1) Codex / ChatGPT OAuth (기본)
#    `codex login` 으로 로그인하면 ~/.codex/auth.json 가 생성되며 자동 사용됩니다.
#    별도 env 불필요.

# 2) 일반 OpenAI API 키
# OPENAI_API_KEY=sk-...

# 3) 로컬 모델 (Ollama / LM Studio / MLX 등 OpenAI 호환 서버)
#    예: Ollama — `ollama serve` 후 아래 두 줄만 설정(키 불필요)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=gemma3:12b         # 권장 로컬 모델 (qwen3:14b도 OK). 날짜는 코드 리졸버가 보정

# 모델 오버라이드 (선택)
#   - Codex(ChatGPT 계정): gpt-5.4-mini(기본) / gpt-5.4 / gpt-5.5
#   - OPENAI_API_KEY 사용 시 기본값: gpt-4o-mini
# LLM_MODEL=gpt-5.4-mini

# ── 구글 캘린더 양방향 동기화 (선택) ──
# Google Cloud Console에서 OAuth 클라이언트 생성 후 설정.
# 승인된 리디렉션 URI: http://localhost:8000/oauth/google/callback
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxx
# GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/google/callback   # 기본은 요청 host로 자동
